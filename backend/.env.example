# Copie este arquivo para .env e preencha com seus valores reais.
# O .env nunca deve ser commitado (está no .gitignore).

# Conexão com o PostgreSQL.
# Default local casa com o docker-compose.yml: porta 5433 (a 5432 fica para o
# Postgres nativo, se você tiver instalado).
DATABASE_URL=postgresql+asyncpg://skytime:skytime_dev@localhost:5433/skytime
